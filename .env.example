# ─── База данных ───────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@localhost:5432/volleydzen"
REDIS_URL="redis://localhost:6379"

# ─── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="your_bot_token"   # Токен из @BotFather
NEXT_PUBLIC_TMA_URL="https://your-ngrok-url.ngrok.io"

# ─── Платежи (ЮKassa) ──────────────────────────────────────
YOOKASSA_SHOP_ID="your_shop_id"
YOOKASSA_SECRET_KEY="your_secret_key"
# URL, куда ЮKassa перенаправит пользователя после оплаты (Success/Fail)
YOOKASSA_RETURN_URL="https://your-domain.com/payment/result"
# Список доверенных IP ЮKassa для проверки входящих уведомлений (Webhooks)
YOOKASSA_WEBHOOK_IP_WHITELIST="185.71.76.0/27,185.71.77.0/27"

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET="min-32-chars-random-string"
JWT_EXPIRES_IN="7d"

# ─── Email (SendGrid) ──────────────────────────────────────
SENDGRID_API_KEY="your_sendgrid_key"
EMAIL_FROM="noreply@volleydzen.ru"

# ─── Мониторинг ────────────────────────────────────────────
SENTRY_DSN="https://..."
