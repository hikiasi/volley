# ─── База данных ───────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@localhost:5432/volleydzen"
REDIS_URL="redis://localhost:6379"

# ─── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="your_bot_token"   # Токен из @BotFather
TELEGRAM_BOT_SECRET="your_bot_secret" # Для HMAC верификации initData
NEXT_PUBLIC_TMA_URL="https://t.me/your_bot/app"

# ─── Платежи ───────────────────────────────────────────────
YOOKASSA_SHOP_ID="your_shop_id"
YOOKASSA_SECRET_KEY="your_secret_key"
YOOKASSA_RETURN_URL="https://volleydzen.ru/payment/success"
YOOKASSA_WEBHOOK_IP_WHITELIST="185.71.76.0/27,185.71.77.0/27"

# ─── Хранилище (Timeweb S3) ────────────────────────────────
S3_ENDPOINT="https://s3.timeweb.cloud"
S3_BUCKET="volleydzen-media"
S3_ACCESS_KEY="your_access_key"
S3_SECRET_KEY="your_secret_key"

# ─── Карты ─────────────────────────────────────────────────
NEXT_PUBLIC_YANDEX_MAPS_KEY="your_yandex_maps_key"

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET="min-32-chars-random-string"
JWT_EXPIRES_IN="7d"

# ─── Email ─────────────────────────────────────────────────
SENDGRID_API_KEY="your_sendgrid_key"
EMAIL_FROM="noreply@volleydzen.ru"

# ─── Мониторинг ────────────────────────────────────────────
SENTRY_DSN="https://..."
