// Prisma Schema для VOLLEYDZEN
// PostgreSQL 15 + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════════
// ПОЛЬЗОВАТЕЛИ И РОЛИ
// ════════════════════════════════════════════════════════════

enum UserRole {
  user
  trainer
  admin
}

enum PlayLevel {
  beginner
  amateur
  advanced
  pro
}

model User {
  id                    String    @id @default(uuid())
  telegramId            BigInt?   @unique @map("telegram_id")
  role                  UserRole  @default(user)

  // Данные из Telegram
  firstName             String    @map("first_name") @db.VarChar(100)
  lastName              String?   @map("last_name") @db.VarChar(100)
  username              String?   @unique @db.VarChar(100)
  photoUrl              String?   @map("photo_url") @db.Text

  // Обязательные для оплаты
  phone                 String?   @db.VarChar(20)
  email                 String?   @db.VarChar(255)
  password              String?   @db.Text

  // Профиль игрока
  playLevel             PlayLevel? @map("play_level")
  ensoLevelId           String?   @map("enso_level_id")
  ensoPoints            Int       @default(0) @map("enso_points")

  // Настройки
  notificationsEnabled  Boolean   @default(true) @map("notifications_enabled")
  isBlocked             Boolean   @default(false) @map("is_blocked")

  // Даты
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  lastActiveAt          DateTime? @map("last_active_at")

  // Связи
  ensoLevel             EnsoLevel?           @relation(fields: [ensoLevelId], references: [id])
  bookings              Booking[]
  userCourses           UserCourse[]
  payments              Payment[]
  testResults           TestResult[]
  videoReviews          VideoReview[]        @relation("StudentReviews")
  trainerReviews        VideoReview[]        @relation("TrainerReviews")
  notifications         Notification[]
  achievements          UserAchievement[]
  promoCodeUsages       PromoCodeUsage[]
  adminInvitesSent      AdminInvite[]        @relation("InvitedBy")
  auditLogs             AuditLog[]
  waitlistEntries       WaitlistEntry[]
  verificationCodes     VerificationCode[]
  chatMessages          ChatMessage[]

  @@index([role])
  @@index([username])
  @@index([email])
  @@map("users")
}

model AdminInvite {
  id              String    @id @default(uuid())
  invitedByUserId String    @map("invited_by_user_id")
  telegramId      BigInt?   @map("telegram_id")
  role            UserRole
  token           String    @unique @db.VarChar(64)
  used            Boolean   @default(false)
  expiresAt       DateTime  @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  invitedBy       User      @relation("InvitedBy", fields: [invitedByUserId], references: [id])

  @@map("admin_invites")
}

// ════════════════════════════════════════════════════════════
// КЭМПЫ
// ════════════════════════════════════════════════════════════

enum CampStatus {
  draft
  published
  full
  completed
  cancelled
}

model Camp {
  id                   String      @id @default(uuid())
  slug                 String      @unique @db.VarChar(255)
  title                String      @db.VarChar(255)
  description          String?     @db.Text
  level                String      @db.VarChar(50) // Shoshin / Shugyosha / Jukuren / Satori

  // Локация
  city                 String      @db.VarChar(100)
  venueName            String?     @map("venue_name") @db.VarChar(255)
  address              String?     @db.Text
  lat                  Decimal?    @db.Decimal(10, 8)
  lng                  Decimal?    @db.Decimal(11, 8)
  yandexMapsUrl        String?     @map("yandex_maps_url") @db.Text

  // Даты
  startDate            DateTime    @map("start_date") @db.Date
  endDate              DateTime    @map("end_date") @db.Date
  durationDays         Int         @map("duration_days")

  // Цены
  basePrice            Int         @map("base_price") // копейки
  depositAmount        Int?        @map("deposit_amount")

  // Участники
  maxParticipants      Int         @map("max_participants")
  currentParticipants  Int         @default(0) @map("current_participants")

  // Статус
  status               CampStatus  @default(draft)

  // Медиа
  coverImageUrl        String?     @map("cover_image_url") @db.Text
  gallery              Json?       // ["url1", "url2"]

  // Расписание
  assemblyTime         DateTime?   @map("assembly_time") @db.Time
  startTime            DateTime?   @map("start_time") @db.Time

  // Информация
  whatToBring          Json?       @map("what_to_bring") // [{"item":"Вода"}]
  whatsIncluded        Json?       @map("whats_included")
  hotMessage           String?     @map("hot_message") @db.VarChar(500)
  parkingInfo          String?     @map("parking_info") @db.Text

  // Рейтинг
  rating               Decimal?    @db.Decimal(3, 2)
  reviewsCount         Int         @default(0) @map("reviews_count")

  // Контакты
  organizerPhone       String?     @map("organizer_phone") @db.VarChar(20)
  organizerTelegram    String?     @map("organizer_telegram") @db.VarChar(100)

  // Файлы
  icsFileUrl           String?     @map("ics_file_url") @db.Text
  participantsChatUrl  String?     @map("participants_chat_url") @db.Text
  memoUrl              String?     @map("memo_url") @db.Text

  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  // Связи
  days                 CampDay[]
  trainers             CampTrainer[]
  bookings             Booking[]
  waitlistEntries      WaitlistEntry[]
  chatMessages         ChatMessage[]

  @@index([status])
  @@index([startDate])
  @@index([city])
  @@map("camps")
}

model CampDay {
  id          String  @id @default(uuid())
  campId      String  @map("camp_id")
  dayNumber   Int     @map("day_number")
  title       String  @db.VarChar(255)
  description String? @db.Text
  isOptional  Boolean @default(false) @map("is_optional")
  extraPrice  Int     @default(0) @map("extra_price") // копейки

  camp        Camp    @relation(fields: [campId], references: [id], onDelete: Cascade)
  options     CampDayOption[]

  @@unique([campId, dayNumber])
  @@map("camp_days")
}

model CampDayOption {
  id          String  @id @default(uuid())
  campDayId   String  @map("camp_day_id")
  title       String  @db.VarChar(255)
  description String? @db.Text
  price       Int     // копейки

  campDay     CampDay @relation(fields: [campDayId], references: [id], onDelete: Cascade)

  @@map("camp_day_options")
}

model Trainer {
  id              String   @id @default(uuid())
  name            String   @db.VarChar(255)
  bio             String?  @db.Text
  photoUrl        String?  @map("photo_url") @db.Text
  specialization  String?  @db.VarChar(255)
  instagramUrl    String?  @map("instagram_url") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  camps           CampTrainer[]
  courses         Course[]

  @@map("trainers")
}

model CampTrainer {
  id        String @id @default(uuid())
  campId    String @map("camp_id")
  trainerId String @map("trainer_id")

  camp      Camp   @relation(fields: [campId], references: [id], onDelete: Cascade)
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([campId, trainerId])
  @@map("camp_trainers")
}

// ════════════════════════════════════════════════════════════
// БРОНИРОВАНИЯ
// ════════════════════════════════════════════════════════════

enum BookingStatus {
  pre_booked
  deposit_paid
  fully_paid
  cancelled
  refunded
}

enum PaymentType {
  full
  deposit
  installment
}

model Booking {
  id                String        @id @default(uuid())
  userId            String        @map("user_id")
  campId            String        @map("camp_id")
  status            BookingStatus @default(pre_booked)
  paymentType       PaymentType   @map("payment_type")

  // Суммы (копейки)
  baseAmount        Int           @map("base_amount")
  optionsAmount     Int           @default(0) @map("options_amount")
  discountAmount    Int           @default(0) @map("discount_amount")
  totalAmount       Int           @map("total_amount")
  paidAmount        Int           @default(0) @map("paid_amount")
  remainingAmount   Int           @default(0) @map("remaining_amount")

  promoCodeId       String?       @map("promo_code_id")

  // Предбронирование
  preBookedAt       DateTime?     @map("pre_booked_at")
  preBookExpiresAt  DateTime?     @map("pre_book_expires_at")

  // Согласия
  pdpConsent        Boolean       @default(false) @map("pdp_consent")
  waiverConsent     Boolean       @default(false) @map("waiver_consent")
  photoVideoConsent Boolean?      @map("photo_video_consent")

  selectedDayIds    Json?         @map("selected_day_ids") // ["uuid1", "uuid2"]
  notes             String?       @db.Text
  receiptUrl        String?       @map("receipt_url") @db.Text

  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user              User          @relation(fields: [userId], references: [id])
  camp              Camp          @relation(fields: [campId], references: [id])
  promoCode         PromoCode?    @relation(fields: [promoCodeId], references: [id])
  payments          Payment[]

  @@index([userId])
  @@index([campId])
  @@index([status])
  @@map("bookings")
}

// ════════════════════════════════════════════════════════════
// ПЛАТЕЖИ
// ════════════════════════════════════════════════════════════

enum PaymentStatus {
  pending
  waiting_for_capture
  succeeded
  cancelled
  refunded
}

enum PaymentMethod {
  sbp
  bank_card
  yoo_money
  installment
}

model Payment {
  id                  String         @id @default(uuid())
  bookingId           String?        @map("booking_id")
  userCourseId        String?        @map("user_course_id")
  userId              String         @map("user_id")

  yookassaPaymentId   String?        @unique @map("yookassa_payment_id") @db.VarChar(255)
  amount              Int            // копейки
  currency            String         @default("RUB") @db.VarChar(3)
  status              PaymentStatus  @default(pending)
  paymentMethod       PaymentMethod? @map("payment_method")

  description         String?        @db.Text
  confirmationUrl     String?        @map("confirmation_url") @db.Text
  metadata            Json?

  capturedAt          DateTime?      @map("captured_at")
  createdAt           DateTime       @default(now()) @map("created_at")

  user                User           @relation(fields: [userId], references: [id])
  booking             Booking?       @relation(fields: [bookingId], references: [id])
  userCourse          UserCourse?    @relation(fields: [userCourseId], references: [id])
  installments        PaymentInstallment[]

  @@index([userId])
  @@index([status])
  @@map("payments")
}

model PaymentInstallment {
  id          String   @id @default(uuid())
  paymentId   String   @map("payment_id")
  amount      Int      // копейки
  dueDate     DateTime @map("due_date") @db.Date
  status      String   @db.VarChar(50)
  paidAt      DateTime? @map("paid_at")

  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("payment_installments")
}

// ════════════════════════════════════════════════════════════
// ПРОМОКОДЫ
// ════════════════════════════════════════════════════════════

enum DiscountType {
  percentage
  fixed_amount
}

enum ApplicableTo {
  all
  camps
  courses
  merch
}

model PromoCode {
  id              String        @id @default(uuid())
  code            String        @unique @db.VarChar(50)
  discountType    DiscountType  @map("discount_type")
  discountValue   Int           @map("discount_value")
  maxUses         Int?          @map("max_uses")
  usedCount       Int           @default(0) @map("used_count")
  validFrom       DateTime      @map("valid_from")
  validUntil      DateTime      @map("valid_until")
  applicableTo    ApplicableTo  @map("applicable_to")
  specificItemId  String?       @map("specific_item_id")
  isActive        Boolean       @default(true) @map("is_active")
  createdByAdminId String       @map("created_by_admin_id")
  createdAt       DateTime      @default(now()) @map("created_at")

  bookings        Booking[]
  usages          PromoCodeUsage[]

  @@map("promo_codes")
}

model PromoCodeUsage {
  id          String   @id @default(uuid())
  promoCodeId String   @map("promo_code_id")
  userId      String   @map("user_id")
  usedAt      DateTime @default(now()) @map("used_at")

  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@map("promo_code_usages")
}

// ════════════════════════════════════════════════════════════
// КУРСЫ
// ════════════════════════════════════════════════════════════

enum CourseCategory {
  jump
  speed
  upper_body
  free
}

enum CourseLevel {
  beginner
  intermediate
  advanced
}

enum CourseStatus {
  draft
  published
  archived
}

model Course {
  id                String         @id @default(uuid())
  slug              String         @unique @db.VarChar(255)
  title             String         @db.VarChar(255)
  category          CourseCategory
  description       String?        @db.Text
  expectedResult    String?        @map("expected_result") @db.VarChar(255)
  level             CourseLevel
  durationWeeks     Int            @map("duration_weeks")
  minutesPerDay     String?        @map("minutes_per_day") @db.VarChar(50)
  price             Int            // копейки
  installmentPrice  Int?           @map("installment_price")
  coverImageUrl     String?        @map("cover_image_url") @db.Text
  previewVideoUrl   String?        @map("preview_video_url") @db.Text
  trainerId         String?        @map("trainer_id")
  requirements      String?        @db.Text
  suitableFor       Json?          @map("suitable_for")
  notSuitableFor    Json?          @map("not_suitable_for")
  refundDays        Int            @default(7) @map("refund_days")
  status            CourseStatus   @default(draft)
  rating            Decimal?       @db.Decimal(3, 2)
  reviewsCount      Int            @default(0) @map("reviews_count")
  isFeatured        Boolean        @default(false) @map("is_featured")
  sortOrder         Int            @default(0) @map("sort_order")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  trainer           Trainer?       @relation(fields: [trainerId], references: [id])
  weeks             CourseWeek[]
  userCourses       UserCourse[]

  @@index([category])
  @@index([status])
  @@map("courses")
}

model CourseWeek {
  id          String       @id @default(uuid())
  courseId    String       @map("course_id")
  weekNumber  Int          @map("week_number")
  title       String       @db.VarChar(255)
  description String?      @db.Text
  isFree      Boolean      @default(false) @map("is_free")

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  days        CourseDay[]

  @@unique([courseId, weekNumber])
  @@map("course_weeks")
}

model CourseDay {
  id          String              @id @default(uuid())
  weekId      String              @map("week_id")
  dayNumber   Int                 @map("day_number")
  title       String              @db.VarChar(255)
  description String?             @db.Text
  isFree      Boolean             @default(false) @map("is_free")

  week        CourseWeek          @relation(fields: [weekId], references: [id], onDelete: Cascade)
  exercises   CourseDayExercise[]
  progress    UserDayProgress[]
  videoReviews VideoReview[]

  @@unique([weekId, dayNumber])
  @@map("course_days")
}

// ════════════════════════════════════════════════════════════
// УПРАЖНЕНИЯ
// ════════════════════════════════════════════════════════════

enum ExerciseCategory {
  warmup
  main
  plyometric
  cooldown
  test
}

enum ExerciseDifficulty {
  easy
  medium
  hard
}

model Exercise {
  id                   String             @id @default(uuid())
  title                String             @db.VarChar(255)
  category             ExerciseCategory
  difficulty           ExerciseDifficulty
  vimeoVideoId         String?            @map("vimeo_video_id") @db.VarChar(100)
  videoDurationSeconds Int?               @map("video_duration_seconds")
  thumbnailUrl         String?            @map("thumbnail_url") @db.Text
  techniqueSteps       Json?              @map("technique_steps")
  commonMistakes       Json?              @map("common_mistakes")
  safetyNotes          Json?              @map("safety_notes")
  setsDefault          Int?               @map("sets_default")
  repsDefault          Int?               @map("reps_default")
  durationSeconds      Int?               @map("duration_seconds")
  restSeconds          Int?               @map("rest_seconds")
  createdAt            DateTime           @default(now()) @map("created_at")

  courseDayExercises   CourseDayExercise[]
  userProgress         UserExerciseProgress[]

  @@map("exercises")
}

model CourseDayExercise {
  id            String       @id @default(uuid())
  courseDayId   String       @map("course_day_id")
  exerciseId    String       @map("exercise_id")
  section       String       @db.VarChar(50) // warmup, main, plyometric, cooldown
  orderIndex    Int          @map("order_index")
  sets          Int?
  reps          Int?
  durationSecs  Int?         @map("duration_secs")
  restSecs      Int?         @map("rest_secs")
  notes         String?      @db.Text

  courseDay     CourseDay    @relation(fields: [courseDayId], references: [id], onDelete: Cascade)
  exercise      Exercise     @relation(fields: [exerciseId], references: [id])

  @@unique([courseDayId, exerciseId, orderIndex])
  @@map("course_day_exercises")
}

// ════════════════════════════════════════════════════════════
// ПРОГРЕСС ПОЛЬЗОВАТЕЛЯ
// ════════════════════════════════════════════════════════════

enum UserCourseStatus {
  active
  completed
  cancelled
}

model UserCourse {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  courseId        String            @map("course_id")
  status          UserCourseStatus  @default(active)
  tier            String?           @db.VarChar(50) // review_lite / review_pro / full_coaching
  progress        Int               @default(0) // процент
  currentWeek     Int               @default(1) @map("current_week")
  currentDay      Int               @default(1) @map("current_day")
  startedAt       DateTime          @default(now()) @map("started_at")
  completedAt     DateTime?         @map("completed_at")
  lastActivityAt  DateTime?         @map("last_activity_at")

  user            User              @relation(fields: [userId], references: [id])
  course          Course            @relation(fields: [courseId], references: [id])
  dayProgress     UserDayProgress[]
  exerciseProgress UserExerciseProgress[]
  videoReviews    VideoReview[]
  payments        Payment[]

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("user_courses")
}

model UserDayProgress {
  id            String      @id @default(uuid())
  userCourseId  String      @map("user_course_id")
  courseDayId   String      @map("course_day_id")
  isCompleted   Boolean     @default(false) @map("is_completed")
  rpe           Int?        // 1-10
  completedAt   DateTime?   @map("completed_at")

  userCourse    UserCourse  @relation(fields: [userCourseId], references: [id], onDelete: Cascade)
  courseDay     CourseDay   @relation(fields: [courseDayId], references: [id])

  @@unique([userCourseId, courseDayId])
  @@map("user_day_progress")
}

model UserExerciseProgress {
  id            String      @id @default(uuid())
  userCourseId  String      @map("user_course_id")
  exerciseId    String      @map("exercise_id")
  isViewed      Boolean     @default(false) @map("is_viewed")
  isCompleted   Boolean     @default(false) @map("is_completed")
  viewedAt      DateTime?   @map("viewed_at")
  completedAt   DateTime?   @map("completed_at")

  userCourse    UserCourse  @relation(fields: [userCourseId], references: [id], onDelete: Cascade)
  exercise      Exercise    @relation(fields: [exerciseId], references: [id])

  @@unique([userCourseId, exerciseId])
  @@map("user_exercise_progress")
}

model TestResult {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  testType    String   @db.VarChar(50) // CMJ, spike_height, etc
  value       Decimal  @db.Decimal(10, 2)
  unit        String   @db.VarChar(20) // cm, kg, sec
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, testType])
  @@map("test_results")
}

enum VideoReviewStatus {
  pending
  reviewed
}

model VideoReview {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  trainerId       String            @map("trainer_id")
  userCourseId    String            @map("user_course_id")
  courseDayId     String            @map("course_day_id")
  videoUrl        String            @map("video_url") @db.Text
  userComment     String?           @map("user_comment") @db.Text
  rpe             Int?
  status          VideoReviewStatus @default(pending)
  trainerFeedback String?           @map("trainer_feedback") @db.Text
  trainerVideoUrl String?           @map("trainer_video_url") @db.Text
  reviewedAt      DateTime?         @map("reviewed_at")
  createdAt       DateTime          @default(now()) @map("created_at")

  user            User              @relation("StudentReviews", fields: [userId], references: [id])
  trainer         User              @relation("TrainerReviews", fields: [trainerId], references: [id])
  userCourse      UserCourse        @relation(fields: [userCourseId], references: [id])
  courseDay       CourseDay         @relation(fields: [courseDayId], references: [id])

  @@index([trainerId, status])
  @@map("video_reviews")
}

// ════════════════════════════════════════════════════════════
// УВЕДОМЛЕНИЯ
// ════════════════════════════════════════════════════════════

model Notification {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  title       String    @db.VarChar(255)
  body        String    @db.Text
  type        String    @db.VarChar(50)
  actionUrl   String?   @map("action_url") @db.Text
  isRead      Boolean   @default(false) @map("is_read")
  sentAt      DateTime  @default(now()) @map("sent_at")
  readAt      DateTime? @map("read_at")

  user        User      @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model NotificationTemplate {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  title       String   @db.VarChar(255)
  body        String   @db.Text
  variables   Json?    // ["userName", "campTitle"]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("notification_templates")
}

// ════════════════════════════════════════════════════════════
// ПУТЬ ЭНСО (Фаза 2)
// ════════════════════════════════════════════════════════════

model EnsoLevel {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(50) // Shoshin, Shugyosha, Jukuren, Satori
  description String?  @db.Text
  minPoints   Int      @map("min_points")
  maxPoints   Int?     @map("max_points")
  iconUrl     String?  @map("icon_url") @db.Text
  orderIndex  Int      @map("order_index")

  users       User[]

  @@map("enso_levels")
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String   @db.VarChar(50) // camps_attended, course_completed
  value       Int
  earnedAt    DateTime @default(now()) @map("earned_at")

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_achievements")
}

// ════════════════════════════════════════════════════════════
// МЕРЧ (Фаза 2)
// ════════════════════════════════════════════════════════════

model MerchProduct {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  price       Int      // копейки
  imageUrl    String?  @map("image_url") @db.Text
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("merch_products")
}

model MerchOrder {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  items       Json     // [{"productId": "...", "quantity": 2}]
  totalAmount Int      @map("total_amount")
  status      String   @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("merch_orders")
}

// ════════════════════════════════════════════════════════════
// ОФЛАЙН ТРЕНИРОВКИ (Фаза 2)
// ════════════════════════════════════════════════════════════

model OfflineTraining {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(255)
  date        DateTime @db.Date
  time        DateTime @db.Time
  location    String   @db.VarChar(255)
  price       Int      // копейки
  maxSlots    Int      @map("max_slots")
  bookedSlots Int      @default(0) @map("booked_slots")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("offline_trainings")
}

// ════════════════════════════════════════════════════════════
// АУДИТ
// ════════════════════════════════════════════════════════════

model AuditLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  action      String   @db.VarChar(100)
  entityType  String   @map("entity_type") @db.VarChar(50)
  entityId    String?  @map("entity_id")
  changes     Json?
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_log")
}

model WaitlistEntry {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  campId    String   @map("camp_id")
  position  Int
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])
  camp Camp @relation(fields: [campId], references: [id])

  @@unique([userId, campId])
  @@map("waitlist_entries")
}

model VerificationCode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   // "phone" or "email"
  code      String   @db.VarChar(10)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("verification_codes")
}

model ChatMessage {
  id        String   @id @default(uuid())
  campId    String   @map("camp_id")
  userId    String   @map("user_id")
  text      String?  @db.Text
  type      String   @default("text") // "text", "system", "video", "image"
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  camp Camp @relation(fields: [campId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("chat_messages")
}
